for i = 1:length(clusterInfo)
    oldTitle = clusterInfo(i).wfTitle;

    % Find the slope number using regular expression
    expr = 'Slope:(\d+\.?\d*) uV';
    tokens = regexp(oldTitle, expr, 'tokens');

    if ~isempty(tokens)
        slope_uvs = str2double(tokens{1}{1});      % extract uV/s
        %slope_uvms = slope_uvs / 1000;              % convert to uV/ms

        % Create the new string
        newSlopeStr = sprintf('Slope:%.2f uV/ms', slope_uvs);%ALREADY  IN  uv/ms

        % Replace in the original title
        newTitle = regexprep(oldTitle, expr, newSlopeStr);

        % Update the struct
        clusterInfo(i).wfTitle = newTitle;
    end
end

