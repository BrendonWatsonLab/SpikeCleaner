% 
% 
% 
function wrappedStr = wraptext(inputStr, maxCharsPerLine)
    % Split into words
    words = strsplit(inputStr);
    currentLine = '';
    lines = {};

    for i = 1:length(words)
        word = words{i};
        % Check length if we add this word
        if isempty(currentLine)
            newLine = word;
        else
            newLine = [currentLine ' ' word];
        end

        if length(newLine) <= maxCharsPerLine
            % Fits in current line
            currentLine = newLine;
        else
            % Push currentLine into lines
            lines{end+1} = currentLine; %#ok<AGROW>
            currentLine = word;
        end
    end

    % Append last line
    if ~isempty(currentLine)
        lines{end+1} = currentLine; %#ok<AGROW>
    end

    % Join with newlines
    wrappedStr = strjoin(lines, '\n');
end